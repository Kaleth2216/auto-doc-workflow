    {
      "parameters": {
        "jsCode": "const nuevoReadme = $('Enviar a Ollama').item.json.response;\nconst contenidoBase64 = Buffer.from(nuevoReadme).toString('base64');\nconst shaActual = $('Obtener README').item.json.sha;\n\nreturn {\n  json: {\n    contenidoBase64: contenidoBase64,\n    shaActual: shaActual\n  }\n};"
      },
